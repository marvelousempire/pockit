#!/usr/bin/env bash
# Pockit sibling CLI — Plan 0468 (Phase 1 bridge · Phase 2 operator-runtime).
set -euo pipefail

POCKIT_ROOT="$(cd "$(dirname "$0")/.." && pwd -P)"
BRIDGE="$POCKIT_ROOT/operator-bridge.json"

resolve_nephew_root() {
  local default="$HOME/Developer/nephew"
  if [[ -f "$BRIDGE" ]]; then
    local bridged
    bridged="$(node -e "
      const b = require(process.argv[1]);
      const d = require('node:os').homedir() + '/Developer/nephew';
      process.stdout.write(b.nephew_root || d);
    " "$BRIDGE")"
    if [[ -n "${POCKIT_NEPHEW_OVERRIDE:-}" && -n "${NEPHEW_ROOT:-}" && -f "${NEPHEW_ROOT}/scripts/pockit-smart.sh" ]]; then
      echo "$NEPHEW_ROOT"
      return
    fi
    if [[ -f "$bridged/scripts/pockit-smart.sh" ]]; then
      echo "$bridged"
      return
    fi
  fi
  if [[ -n "${NEPHEW_ROOT:-}" && -f "${NEPHEW_ROOT}/scripts/pockit-smart.sh" ]]; then
    echo "$NEPHEW_ROOT"
    return
  fi
  echo "$default"
}

bridge_phase() {
  if [[ ! -f "$BRIDGE" ]]; then
    echo "1"
    return
  fi
  node -e "const b=require(process.argv[1]); process.stdout.write(String(b.phase||1))" "$BRIDGE"
}

surface_version() {
  local nep="$1"
  local phase
  phase="$(bridge_phase)"
  local candidates=()
  if [[ "$phase" -ge 2 && -f "$POCKIT_ROOT/operator-runtime/family-hub/pockit-surface.json" ]]; then
    candidates+=("$POCKIT_ROOT/operator-runtime/family-hub/pockit-surface.json")
  fi
  if [[ -f "$BRIDGE" ]]; then
    candidates+=("$nep/containers/nephew-ct/family-hub/pockit-surface.json")
  fi
  candidates+=("$POCKIT_ROOT/shell/pockit-surface.json")
  candidates+=("$nep/containers/nephew-ct/family-hub/pockit-surface.json")
  for f in "${candidates[@]}"; do
    if [[ -f "$f" ]]; then
      node -e "const v=require(process.argv[1]).version; console.log('Pockit', v)" "$f"
      return 0
    fi
  done
  echo "Pockit (version unknown — no surface JSON)"
  return 1
}

usage() {
  cat <<'EOF'
pockit — Family Office player frame (sibling repo)

  pockit up      Boot operator stack (delegates to nephew)
  pockit open    Open http://pockit.localhost/
  pockit version Print live surface version
  pockit serve   Static serve family-hub from pockit repo (Phase 2+)

Phase 2: operator-runtime/family-hub lives in this repo; gateway resolves via operator-bridge.json.
EOF
}

cmd="${1:-}"
shift || true

case "$cmd" in
  up)
    NEP="$(resolve_nephew_root)"
    export NEPHEW_ROOT="$NEP"
    exec bash "$NEP/scripts/pockit-smart.sh" "$@"
    ;;
  open)
    open "http://pockit.localhost/"
    ;;
  version)
    NEP="$(resolve_nephew_root)"
    surface_version "$NEP"
    ;;
  serve)
    NEP="$(resolve_nephew_root)"
    export NEPHEW_ROOT="$NEP"
    export POCKIT_REPO_DEST="$POCKIT_ROOT"
    exec node "$NEP/scripts/pockit-family-hub-serve.mjs" "$@"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    echo "unknown subcommand: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac